node_modules/

# 按书组织：保留 书籍/ 目录本身，但忽略每本书的内容与运行状态
书籍/*
!书籍/.gitkeep

# 状态/日志/锁一律不入库
**/state.json
**/run.log
*.log
*.error.txt

.env
.env.*

# 本机番茄账号登录态映射（真实 Profile 路径不入库）
config/local/*.json
!config/local/.gitkeep

*.tmp
*.bak

Thumbs.db
Desktop.ini
.DS_Store

# 压力测试临时数据
stress-test-data/

# 启动日志
logs/

# 榜单截图与浏览器核验截图只作本机证据，不提交仓库
research/
