{
  "name": "@novel-pipeline/runners",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "outline": "tsx src/outline-runner.ts",
    "adapt": "tsx src/adapt-runner.ts",
    "generate": "tsx src/generate-runner.ts",
    "outline:dry": "tsx src/outline-runner.ts --dry-run",
    "adapt:dry": "tsx src/adapt-runner.ts --dry-run",
    "generate:dry": "tsx src/generate-runner.ts --dry-run"
  },
  "dependencies": {
    "@novel-pipeline/shared": "workspace:*",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
