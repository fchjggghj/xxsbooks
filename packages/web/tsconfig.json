{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@novel-pipeline/shared": ["../shared/src"],
      "@novel-pipeline/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
