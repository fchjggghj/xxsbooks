{
  "name": "gpts-queue",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Send local chapter files to a custom GPTS queue and save replies locally.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "chrome": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-chrome.ps1",
    "start": "npm run chai",
    "dry-run": "npm run chai:dry",
    "force": "npm run chai:force",
    "pipeline": "npm run chai && npm run xie",
    "pipeline:dry": "npm run chai:dry && npm run xie:dry",
    "chai": "node gpts-queue.mjs --config config-chai.json",
    "chai:dry": "node gpts-queue.mjs --config config-chai.json --dry-run",
    "chai:force": "node gpts-queue.mjs --config config-chai.json --force",
    "chai:reset": "node gpts-queue.mjs --config config-chai.json --reset-state --dry-run",
    "xie": "node gpts-queue.mjs --config config-xie.json",
    "xie:dry": "node gpts-queue.mjs --config config-xie.json --dry-run",
    "xie:force": "node gpts-queue.mjs --config config-xie.json --force",
    "xie:reset": "node gpts-queue.mjs --config config-xie.json --reset-state --dry-run",
    "check": "node --check gpts-queue.mjs"
  },
  "dependencies": {
    "playwright-core": "^1.49.0"
  }
}
