{
  "name": "gpts-queue",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Send local chapter files to a custom GPTS queue and save replies locally.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "chrome": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-chrome.ps1",
    "start": "node gpts-queue.mjs",
    "dry-run": "node gpts-queue.mjs --dry-run",
    "force": "node gpts-queue.mjs --force",
    "pipeline": "npm run dagang && npm run zhengwen",
    "pipeline:dry": "npm run dagang:dry && npm run zhengwen:dry",
    "dagang": "node gpts-queue.mjs --config config-dagang.json",
    "dagang:dry": "node gpts-queue.mjs --config config-dagang.json --dry-run",
    "dagang:force": "node gpts-queue.mjs --config config-dagang.json --force",
    "dagang:reset": "node gpts-queue.mjs --config config-dagang.json --reset-state --dry-run",
    "zhengwen": "node gpts-queue.mjs --config config-zhengwen.json",
    "zhengwen:dry": "node gpts-queue.mjs --config config-zhengwen.json --dry-run",
    "zhengwen:force": "node gpts-queue.mjs --config config-zhengwen.json --force",
    "zhengwen:reset": "node gpts-queue.mjs --config config-zhengwen.json --reset-state --dry-run",
    "check": "node --check gpts-queue.mjs"
  },
  "dependencies": {
    "playwright-core": "^1.49.0"
  }
}
