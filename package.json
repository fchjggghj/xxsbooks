{
  "name": "novel-pipeline",
  "version": "2.0.0",
  "private": true,
  "description": "小说流水线：下载 → 拆大纲 → 改编 → 写正文",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @novel-pipeline/web dev",
    "dev:server": "pnpm --filter @novel-pipeline/server dev",
    "dev:all": "pnpm -r --parallel run dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @novel-pipeline/shared build",
    "build:web": "pnpm --filter @novel-pipeline/web build",
    "build:server": "pnpm --filter @novel-pipeline/server build",
    "build:runners": "pnpm --filter @novel-pipeline/runners build",
    "build:orchestrator": "pnpm --filter @novel-pipeline/orchestrator build",
    "lint": "eslint packages --ext .ts,.tsx,.mjs",
    "lint:fix": "eslint packages --ext .ts,.tsx,.mjs --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,mjs,json,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,mjs,json,css}\"",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "pipeline": "tsx packages/orchestrator/src/index.ts",
    "pipeline:dry": "tsx packages/orchestrator/src/index.ts --dry-run",
    "status": "tsx packages/orchestrator/src/status.ts",
    "outline": "tsx packages/runners/src/outline-runner.ts",
    "outline:dry": "tsx packages/runners/src/outline-runner.ts --dry-run",
    "adapt": "tsx packages/runners/src/adapt-runner.ts",
    "adapt:dry": "tsx packages/runners/src/adapt-runner.ts --dry-run",
    "generate": "tsx packages/runners/src/generate-runner.ts",
    "generate:dry": "tsx packages/runners/src/generate-runner.ts --dry-run",
    "start:server": "node packages/server/dist/index.js",
    "clean": "pnpm -r exec rimraf dist node_modules/.cache"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
